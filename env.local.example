# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin password — choose something strong and keep secret
ADMIN_PASS=your-admin-password

# The URL slug for the admin panel (unguessable, e.g. a random string)
# Visit: /admin/<NEXT_PUBLIC_ADMIN_SLUG>
NEXT_PUBLIC_ADMIN_SLUG=your-secret-admin-slug
